# DeepSeek API Key（前往 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=%DEEPSEEK_API_KEY%

# 数据库路径
DATABASE_URL="file:./prisma/data/project.db"

# Session 密钥（生产环境务必替换为随机字符串，长度 >= 32 位）
SESSION_SECRET=change-me-in-production-use-random-32chars

# 企业微信/钉钉 Webhook（可选，不填则跳过推送）
# WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
